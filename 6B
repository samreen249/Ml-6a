s3 = float(input("HDL (s3): "))
s4 = float(input("Triglycerides (s4): "))
s5 = float(input("Blood Sugar Level (s5): "))
s6 = float(input("s6 value: "))
# Create input in 2D format
user_input = [[age, sex, bmi, bp, s1, s2, s3, s4, s5, s6]]
